# SSL Cert Management – Konfigurationsvorlage
# Kopieren nach .env und anpassen.
# Wird von install.sh automatisch erzeugt.

# ── App ──────────────────────────────────────────────────────────────────────
APP_SECRET_KEY=change-me-to-a-long-random-string-in-production
APP_HOST=127.0.0.1
APP_PORT=8000
APP_DEBUG=false

# ── Datenbank ────────────────────────────────────────────────────────────────
# Relativer Pfad funktioniert, wenn WorkingDirectory korrekt gesetzt ist.
DATABASE_URL=sqlite:///./data/sslcertmanagement.db

# ── Admin-Benutzer (nur beim ersten Start von init_db.py ausgewertet) ────────
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123

# ── CSR / Private Key Verschlüsselung ────────────────────────────────────────
# Wird verwendet, um Private Keys verschlüsselt in der DB zu speichern.
# WICHTIG: Langer, zufälliger Wert – nach der ersten Einrichtung NIE ändern!
# Verlust dieses Wertes bedeutet Verlust aller gespeicherten Private Keys.
CSR_KEY_PASSPHRASE=change-me-to-a-long-random-passphrase
